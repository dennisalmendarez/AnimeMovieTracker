@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Navigation

<div class="@CssClass">
    @ChildContent

    @if (ShowAuthButtons)
    {
        <AuthorizeView>
            <Authorized>
                <div class="auth-actions">
                    <button class="dashboard-button" @onclick='() => Navigation.NavigateTo("/dashboard")'>
                        Dashboard
                    </button>

                    <form method="post" action="/auth/logout" class="logout-form">
                        <button type="submit" class="logout-button">Log Out</button>
                    </form>
                </div>
            </Authorized>

            <NotAuthorized>
                <button class="login-button" @onclick='() => Navigation.NavigateTo("/login")'>
                    Log In
                </button>
            </NotAuthorized>
        </AuthorizeView>
    }
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter] public string CssClass { get; set; } = "controls";

    [Parameter] public bool ShowAuthButtons { get; set; } = true;
}