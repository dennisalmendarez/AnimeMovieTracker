@page "/register"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using AnimeMovieTracker.Models
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Navigation

<PageTitle>Create Account</PageTitle>

<section class="auth-section">
    <div class="auth-shell">
        <div class="auth-art-panel">
            <p class="eyebrow">Your personal watchlist</p>
            <h1>Create your tracker account</h1>
            <p>Save favorites, mark what you are watching, and keep your anime and movie progress organized.</p>
        </div>

        <div class="auth-card auth-card-modern">
            <h1>Create account</h1>
            <p class="auth-subtitle">Start building your saved anime and movie library.</p>

            <EditForm Model="registerModel" OnValidSubmit="RegisterUser" class="auth-form">
                <DataAnnotationsValidator />

                <div class="input-group">
                    <label for="email">Email address</label>
                    <InputText
                        id="email"
                        class="auth-input"
                        type="email"
                        autocomplete="email"
                        placeholder="Email address"
                        @bind-Value="registerModel.Email" />
                    <ValidationMessage For="() => registerModel.Email" />
                </div>

                <div class="input-group">
                    <label for="password">Password</label>
                    <InputText
                        id="password"
                        class="auth-input"
                        type="password"
                        autocomplete="new-password"
                        placeholder="Password"
                        @bind-Value="registerModel.Password" />
                    <ValidationMessage For="() => registerModel.Password" />
                </div>

                <div class="input-group">
                    <label for="confirmPassword">Confirm password</label>
                    <InputText
                        id="confirmPassword"
                        class="auth-input"
                        type="password"
                        autocomplete="new-password"
                        placeholder="Confirm password"
                        @bind-Value="registerModel.ConfirmPassword" />
                    <ValidationMessage For="() => registerModel.ConfirmPassword" />
                </div>

                @if (!string.IsNullOrWhiteSpace(errorMessage))
                {
                    <p class="error-text">@errorMessage</p>
                }

                <button type="submit" class="auth-primary-button" disabled="@isSubmitting">
                    @(isSubmitting ? "Creating..." : "Create Account")
                </button>
            </EditForm>

            <p class="auth-footer">
                Already have an account? <a href="/login" class="text-link">Sign in</a>
            </p>
        </div>
    </div>
</section>

@code {
    private RegisterModel registerModel = new();
    private string errorMessage = "";
    private bool isSubmitting;

    private async Task RegisterUser()
    {
        if (isSubmitting)
        {
            return;
        }

        isSubmitting = true;
        errorMessage = "";

        try
        {
            var email = registerModel.Email.Trim();

            var existingUser = await UserManager.FindByEmailAsync(email);
            if (existingUser is not null)
            {
                errorMessage = "An account with this email already exists.";
                return;
            }

            var user = new ApplicationUser
            {
                UserName = email,
                Email = email
            };

            var result = await UserManager.CreateAsync(user, registerModel.Password);

            if (result.Succeeded)
            {
                Navigation.NavigateTo("/login?registered=1", forceLoad: true);
                return;
            }

            errorMessage = string.Join(" ", result.Errors.Select(e => e.Description));
        }
        finally
        {
            isSubmitting = false;
        }
    }

    public class RegisterModel
    {
        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Enter a valid email address.")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "Password is required.")]
        [MinLength(6, ErrorMessage = "Password must be at least 6 characters.")]
        public string Password { get; set; } = "";

        [Required(ErrorMessage = "Confirm your password.")]
        [Compare(nameof(Password), ErrorMessage = "Passwords do not match.")]
        public string ConfirmPassword { get; set; } = "";
    }
}
